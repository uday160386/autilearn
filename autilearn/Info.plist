<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

    <!-- ═══ PRIVACY USAGE DESCRIPTIONS (required for App Store review) ═══ -->
    <key>NSCameraUsageDescription</key>
    <string>AutiLearn uses the camera for Mirror Mode (practise making emotion faces) and to record personalised task demonstration videos.</string>

    <key>NSMicrophoneUsageDescription</key>
    <string>AutiLearn uses the microphone so you can speak in Voice Chat and get a kind, friendly response.</string>

    <key>NSSpeechRecognitionUsageDescription</key>
    <string>AutiLearn listens to what you say in Voice Chat to understand your feelings and reply kindly.</string>

    <key>NSPhotoLibraryUsageDescription</key>
    <string>AutiLearn lets you add photos and videos from your library to your personal Memories book.</string>

    <key>NSPhotoLibraryAddUsageDescription</key>
    <string>AutiLearn saves media you create (videos, photos) to your photo library.</string>

    <!-- ═══ KIOSK / FULL SCREEN ═══ -->
    <!-- Prevents iPad Slide Over and Split View — critical for keeping child in app -->
    <key>UIRequiresFullScreen</key>
    <true/>

    <!-- ═══ AUDIO ═══ -->
    <!-- Allows TTS and voice chat to keep playing when app briefly backgrounds -->
    <key>UIBackgroundModes</key>
    <array>
        <string>audio</string>
    </array>

    <!-- ═══ NETWORK ═══ -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <true/>
        <key>NSExceptionDomains</key>
        <dict>
            <key>youtube.com</key>
            <dict>
                <key>NSIncludesSubdomains</key><true/>
                <key>NSExceptionAllowsInsecureHTTPLoads</key><false/>
            </dict>
            <key>ytimg.com</key>
            <dict>
                <key>NSIncludesSubdomains</key><true/>
                <key>NSExceptionAllowsInsecureHTTPLoads</key><false/>
            </dict>
            <key>youtu.be</key>
            <dict>
                <key>NSIncludesSubdomains</key><true/>
                <key>NSExceptionAllowsInsecureHTTPLoads</key><false/>
            </dict>
            <key>googleapis.com</key>
            <dict>
                <key>NSIncludesSubdomains</key><true/>
                <key>NSExceptionAllowsInsecureHTTPLoads</key><false/>
            </dict>
            <key>unsplash.com</key>
            <dict>
                <key>NSIncludesSubdomains</key><true/>
                <key>NSExceptionAllowsInsecureHTTPLoads</key><false/>
            </dict>
            <key>anthropic.com</key>
            <dict>
                <key>NSIncludesSubdomains</key><true/>
                <key>NSExceptionAllowsInsecureHTTPLoads</key><false/>
            </dict>
        </dict>
    </dict>

    <!-- ═══ GUIDED ACCESS ═══ -->
    <key>UIAccessibilityGuidedAccessRestrictions</key>
    <array/>

</dict>
</plist>
